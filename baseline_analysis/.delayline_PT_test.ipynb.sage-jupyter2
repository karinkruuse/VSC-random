{"cell_type":"code","end":1770362670621,"exec_count":6,"id":"e554cf78-204f-44b0-9a27-ba88a27bad2b","input":"def asd_welch(x, fs, nperseg=2**14, noverlap=None, window=\"hann\",\n              detrend=\"constant\", remove_mean=True, return_psd=False):\n    x = np.asarray(x); \n    if remove_mean: x = x - np.mean(x)\n    if noverlap is None: noverlap = nperseg//2\n    f, P = welch(x, fs, window=window, nperseg=nperseg,\n                 noverlap=noverlap, detrend=detrend, scaling=\"density\")\n    A = np.sqrt(P)\n    return (f, A, P) if return_psd else (f, A)","kernel":"python3","pos":5,"start":1770362670577,"state":"done","type":"cell"}
{"cell_type":"code","end":1770362670668,"exec_count":7,"id":"b9896ba0-9b38-436c-811b-b6b4c61ecad8","input":"def plot_asd(x, fs, nperseg=2**14, fmin=None, fmax=None, label=None):\n    f, P = welch(x - np.mean(x), fs, nperseg=nperseg, noverlap=nperseg//2)\n    A = np.sqrt(P)\n    m = (A > 0)\n    if fmin is not None: m &= f >= fmin\n    if fmax is not None: m &= f <= fmax\n    plt.grid()\n    plt.loglog(f[m], A[m], label=label)\n    plt.xlabel(\"Hz\"); plt.ylabel(\"ASD [units/√Hz]\")\n    if label: plt.legend()","kernel":"python3","pos":6,"start":1770362670626,"state":"done","type":"cell"}
{"cell_type":"code","end":1770362672684,"exec_count":8,"id":"7fcf5be6-f9cb-4d11-a83c-ea9cc2e53562","input":"plot_asd(phi1, fs, fmin=1e-3, label=\"φ1\")\nplot_asd(phi2, fs, fmin=1e-3, label=\"φ₂\")\nplot_asd(phi3, fs, fmin=1e-3, label=\"φ3\")\nplt.ylabel(\"ASD [cycles/√Hz]\")\nplt.show()","kernel":"python3","output":{"0":{"data":{"image/png":"2ce895925ea7c939e12900991064ecdb84f7920f","text/plain":"<Figure size 640x480 with 1 Axes>"}}},"pos":7,"scrolled":true,"start":1770362670671,"state":"done","type":"cell"}
{"cell_type":"code","end":1770362704582,"exec_count":10,"id":"b27c4ef1-916c-4b88-a8cc-eda2ec11cd4f","input":"def D(x, t, tau):\n    td = t - tau\n    m = (td >= t[0]) & (td <= t[-1]) & np.isfinite(x)\n    y = np.full_like(x, np.nan, dtype=float)\n    y[m] = np.interp(td[m], t, x)\n    return y, m\n\n\n# --- compute corrected phi1 on global grid ---\nDf1j, m1 = D(f1*jitters, t, set_delay)\nDf1,  m2 = D(f1,        t, set_delay)\nD_phi1_corrected = phi1 - Df1j + Df1*jitters\n\n# --- delayed phi3 on same grid ---\nDphi3, m3 = D(phi3, t, set_delay)\n\n# --- subtract, then crop once, then ASD ---\nres = D_phi1_corrected - Dphi3\nres2 = phi1 - Dphi3\nm = np.isfinite(res) & m1 & m2 & m3 & np.isfinite(t)\nm2 = np.isfinite(res2) & m3 & np.isfinite(t)\ntv, rv = t[m], res[m]\ntv2, rv2 = t[m2], res[m2]\n\nfs = 1/np.mean(np.diff(tv))\nf, A = asd_welch(rv, fs)\nf2, A2 = asd_welch(rv2, fs)\n\nplt.loglog(f, A); plt.loglog(f2, A2);plt.xlabel(\"Hz\"); plt.ylabel(\"ASD [cycles/√Hz]\"); plt.grid(True, which=\"both\", alpha=0.3)\nplt.show()\n","kernel":"python3","output":{"0":{"data":{"image/png":"7f6371cc51abf959528a4985286f2fc2b0eaf0f2","text/plain":"<Figure size 640x480 with 1 Axes>"}}},"pos":8,"start":1770362701350,"state":"done","type":"cell"}
